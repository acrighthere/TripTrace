# ===== TripTrace environment =====
# Copy to .env and fill in values. Compose reads this file; the values for
# DATABASE_URL / S3_ENDPOINT below target localhost so the prisma CLI and
# `next dev` work from the host — inside compose, the app container gets
# `db` / `minio` hostnames injected by docker-compose.yml.

# --- Auth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Set to the deployed domain in production (https://triptrace.example.com)
NEXTAUTH_URL=http://localhost:3000

# --- Database (swap to managed Postgres in prod by changing this URL only) ---
DATABASE_URL=postgresql://triptrace:triptrace@localhost:5432/triptrace
POSTGRES_USER=triptrace
POSTGRES_PASSWORD=triptrace
POSTGRES_DB=triptrace

# --- Object storage (swap MinIO -> S3/R2 in prod via these vars only) ---
# S3_ENDPOINT: endpoint the *server* uses (inside compose: http://minio:9000)
# S3_PUBLIC_ENDPOINT: endpoint the *browser* can reach for presigned URLs.
# For real S3/R2 both are the same public endpoint.
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=triptrace
S3_REGION=us-east-1

# --- Map ---
# Any MapLibre-compatible style URL (OpenFreeMap needs no API key;
# MapTiler example: https://api.maptiler.com/maps/streets-v2/style.json?key=KEY)
MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# --- Geocoding (city boundaries) ---
# Reverse-geocoder used to fetch a city's admin boundary polygon when a CITY
# is pinned (one request per pinned city, throttled to 1 req/s, cached in the
# DB). Point at a self-hosted Nominatim to keep coordinates fully private.
NOMINATIM_URL=https://nominatim.openstreetmap.org

# --- Email (optional; for password-reset links) ---
# If SMTP_URL is unset, reset links are printed to the server log instead of
# emailed (fine for a single-user self-host). Format: smtp(s)://user:pass@host:port
# SMTP_URL=smtps://user:pass@smtp.example.com:465
# SMTP_FROM=TripTrace <no-reply@yourdomain>

