generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts            Account[]
  sessions            Session[]
  visits              Visit[]
  trips               Trip[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique // sha256 of the raw token sent by email
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

enum VisitType {
  CITY
  PLACE
}

enum VisitStatus {
  VISITED
  WISHLIST
}

model Trip {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  visits Visit[]

  @@index([userId])
}

model Visit {
  id        String      @id @default(cuid())
  userId    String
  type      VisitType
  status    VisitStatus @default(VISITED)
  name      String
  lat       Float
  lng       Float
  parentId  String?
  tripId    String?
  notes     String?
  visitedAt DateTime?
  visitedTo DateTime?
  createdAt DateTime    @default(now())

  // Country a visit sits in. For CITY rows it comes from the Nominatim reverse
  // lookup done at creation; PLACE rows inherit it from their parent city.
  country     String?
  countryCode String? // ISO 3166-1 alpha-2, lowercase
  continent   String?

  // Synced from lat/lng by the visit_geom_sync trigger (see the visit_geom
  // migration); GIST-indexed there too. Declared so migrate dev won't drop it.
  geom Unsupported("geography(Point, 4326)")?

  // CITY rows only: admin boundary polygon from Nominatim (see the
  // city_boundary migration). Declared so migrate dev won't drop it.
  boundary Unsupported("geography(MultiPolygon, 4326)")?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Prisma forbids Cascade on self-relations; child places are deleted
  // in app code (required anyway to clean up their photos' MinIO objects).
  parent   Visit?  @relation("VisitChildren", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Visit[] @relation("VisitChildren")
  trip     Trip?   @relation(fields: [tripId], references: [id], onDelete: SetNull)
  photos   Photo[]

  @@index([userId])
  @@index([parentId])
  @@index([tripId])
  @@index([userId, countryCode])
}

model Photo {
  id         String   @id @default(cuid())
  visitId    String
  storageKey String
  caption    String?
  createdAt  DateTime @default(now())

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}
