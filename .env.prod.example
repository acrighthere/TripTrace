# ===== TripTrace production env =====
# Copy to .env ON THE SERVER and fill in. Replace <IP> with the VM's external IP.
# (DATABASE_URL is not needed here — the app container builds it from POSTGRES_*.)

# --- Auth ---
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# IP/HTTP now. For the domain+TLS stack use https://your.domain instead.
NEXTAUTH_URL=http://<IP>:3000

# --- Database ---
POSTGRES_USER=triptrace
POSTGRES_PASSWORD=          # set a strong password
POSTGRES_DB=triptrace

# --- Object storage (MinIO) ---
S3_ACCESS_KEY=              # NOT minioadmin
S3_SECRET_KEY=              # set a strong password
S3_BUCKET=triptrace
S3_REGION=us-east-1
# Browser-reachable MinIO endpoint — presigned photo URLs are signed for this
# host, so it MUST be reachable from visitors' browsers, not localhost.
# IP/HTTP: http://<IP>:9000   |   domain+TLS: https://s3.your.domain
S3_PUBLIC_ENDPOINT=http://<IP>:9000
# Optional: restrict browser upload origin (default "*" allows any).
# MINIO_CORS_ALLOW_ORIGIN=http://<IP>:3000

# --- Map / geocoding ---
MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
NOMINATIM_URL=https://nominatim.openstreetmap.org
